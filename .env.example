# ========================
# Supabase Configuration
# ========================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# ========================
# Email Service (Resend)
# ========================
RESEND_API_KEY=your-resend-api-key-here
RESEND_FROM_EMAIL=Onagui <noreply@onagui.com>

# Base app URL for verification links
NEXT_PUBLIC_SITE_URL=https://www.onagui.com

# ========================
# Cron Jobs & Security
# ========================
# Generate a random secret: openssl rand -base64 32
CRON_SECRET=your-random-cron-secret-here

# ========================
# Sentry Error Logging (Optional)
# ========================
# Get from https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ========================
# Analytics (Optional)
# ========================
NEXT_PUBLIC_ANALYTICS_ID=

# ========================
# Wallet Configuration
# ========================
# Solana RPC endpoint (optional, uses default if not set)
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ========================
# Network Configuration (Optional)
# ========================
# Set to 'mainnet' or 'testnet'
NEXT_PUBLIC_NETWORK=mainnet

# ========================
# API Configuration (Optional)
# ========================
# Timeout for API requests (in milliseconds)
NEXT_PUBLIC_API_TIMEOUT=30000
