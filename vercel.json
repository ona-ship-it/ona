{
  "buildCommand": "cd src && npm run build",
  "outputDirectory": "src/.next",
  "framework": "nextjs",
  "functions": {
    "src/app/api/**/*.ts": {
      "runtime": "@vercel/node@2.0.0"
    }
  },
  "crons": [
    {
      "path": "/api/cron/draw-winners",
      "schedule": "0 0 * * *"
    }
  ]
}
